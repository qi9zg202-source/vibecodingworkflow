+    }),
+    deriveLoopSnapshot(lowTempProfile, {
+      status: "ok",
+      supplyTempC: 4.9,
+      returnTempC: 9.6,
+      flowTph: 1214,
+      reserveNote: "2 开 1 备，冻结风险下禁止挪用备用机组。",
+      note: "低温环路温差稳定，当前不构成阻断，但任何动作都不能牺牲最小流量。",
